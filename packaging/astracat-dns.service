[Unit]
Description=astracat-dns (balanceDNSt)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=astracat-dns
Group=astracat-dns
ExecStart=/usr/local/bin/astracat-dns --config /etc/astracat-dns/config.toml
Restart=on-failure
RestartSec=1
NoNewPrivileges=true
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target

