# BalanceDNS healthcheck configuration
# Copy to: /etc/default/balancedns-healthcheck
#
# Enable protocol checks. Comma-separated values: udp,doh,dot
BALANCEDNS_CHECK_PROTOCOLS=udp,doh,dot

# Service name
BALANCEDNS_SERVICE_NAME=balancedns

# UDP check target
BALANCEDNS_DNS_SERVER=127.0.0.1
BALANCEDNS_DNS_PORT=53

# DoH check target
BALANCEDNS_DOH_URL=https://127.0.0.1/dns-query
BALANCEDNS_DOH_INSECURE=true

# DoT check target
BALANCEDNS_DOT_SERVER=127.0.0.1
BALANCEDNS_DOT_PORT=853
BALANCEDNS_DOT_SNI=127.0.0.1

# Healthcheck behavior
BALANCEDNS_HEALTHCHECK_DOMAIN=example.com
BALANCEDNS_HEALTHCHECK_TIMEOUT=3
BALANCEDNS_MAX_RETRIES=2
BALANCEDNS_RETRY_DELAY=1
BALANCEDNS_FAILURE_THRESHOLD=3
BALANCEDNS_RESTART_COOLDOWN=30

# Optional metrics endpoint
BALANCEDNS_METRICS_URL=http://127.0.0.1:9100/metrics
