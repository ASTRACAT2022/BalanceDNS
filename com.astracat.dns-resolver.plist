<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.astracat.dns-resolver</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/astracat-dns</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/astracat/Astracat-DNS-Resolver</string>
    <key>StandardOutPath</key>
    <string>/var/log/astracat-dns.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/astracat-dns.error.log</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
